{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"],
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "automation/e2e/specs/.example.cy.ts",
    "automation/e2e/**/*.ts",
    "cypress.config.ts"
  ]
}
